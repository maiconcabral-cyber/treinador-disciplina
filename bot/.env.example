# Token do bot do Telegram (pegue com @BotFather no Telegram)
TELEGRAM_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWXyz

# API key da Anthropic (pegue em https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Modelos (opcionais, têm default no código)
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
RESPONDER_MODEL=claude-sonnet-4-6

# Caminho para o arquivo de storage de usuários (default: ./data/users.json)
STORAGE_PATH=./data/users.json
